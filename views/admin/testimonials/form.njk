{% extends "admin/layout.njk" %}
{% from "admin/_macros.njk" import toggle %}
{% block content %}
<div class="card">
  <div class="card__header"><h2>{{ 'Edit' if item else 'New' }} Testimonial</h2><a class="btn btn-ghost btn-sm" href="/admin/testimonials">← Back</a></div>
  <div class="card__body">
    <form method="post" action="/admin/testimonials{% if item %}/{{ item.TestimonialId }}{% endif %}">
      <div class="form-grid">
        <div class="fg"><label>Author Name *</label><input type="text" name="authorName" required value="{{ item.AuthorName }}"></div>
        <div class="fg"><label>Author Role / Company</label><input type="text" name="authorRole" value="{{ item.AuthorRole }}" placeholder="CEO, Pioneer Foods"></div>
        <div class="fg"><label>Initials (avatar fallback)</label><input type="text" name="initials" value="{{ item.Initials }}" maxlength="4" placeholder="RM"></div>
        <div class="fg"><label>Rating *</label>
          <select name="rating" required>
            <option value="5" {% if (not item) or item.Rating == 5 %}selected{% endif %}>5 Stars</option>
            <option value="4" {% if item.Rating == 4 %}selected{% endif %}>4 Stars</option>
            <option value="3" {% if item.Rating == 3 %}selected{% endif %}>3 Stars</option>
            <option value="2" {% if item.Rating == 2 %}selected{% endif %}>2 Stars</option>
            <option value="1" {% if item.Rating == 1 %}selected{% endif %}>1 Star</option>
          </select>
        </div>
        <div class="fg fg--full"><label>Content *</label><textarea name="content" rows="4" required>{{ item.Content }}</textarea></div>
        <div class="fg"><label>Display Order</label><input type="number" name="displayOrder" value="{{ item.DisplayOrder or 0 }}"></div>
        <div class="fg"><label>Status</label>{{ toggle('isActive', 'Active', (not item) or item.IsActive) }}</div>
      </div>
      <div class="form-actions"><button class="btn btn-primary" type="submit">Save Testimonial</button><a class="btn btn-outline" href="/admin/testimonials">Cancel</a></div>
    </form>
  </div>
</div>
{% endblock %}
