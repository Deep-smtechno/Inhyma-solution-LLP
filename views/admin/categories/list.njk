{% extends "admin/layout.njk" %}
{% from "admin/_macros.njk" import listTop, delBtn, activePill %}
{% block content %}
<div class="card">
  {{ listTop('All Categories', '/admin/categories/new', 'Add Category') }}
  {% if items.length %}
  <div class="table-wrap"><table class="data">
    <thead><tr><th>Image</th><th>Name</th><th>Slug</th><th>Products</th><th>Order</th><th>Status</th><th></th></tr></thead>
    <tbody>
      {% for c in items %}
      <tr>
        <td>{% if c.ImagePath %}<img class="thumb" src="{{ c.ImagePath }}">{% else %}<span class="muted">—</span>{% endif %}</td>
        <td><strong>{{ c.Name }}</strong></td>
        <td class="muted">{{ c.Slug }}</td>
        <td>{{ c.ProductCount }}</td>
        <td>{{ c.DisplayOrder }}</td>
        <td>{{ activePill(c.IsActive) }}</td>
        <td><div class="row-actions"><a class="btn btn-outline btn-sm" href="/admin/categories/{{ c.CategoryId }}/edit">Edit</a>{{ delBtn('/admin/categories/' + (c.CategoryId|string) + '/delete', 'category') }}</div></td>
      </tr>
      {% endfor %}
    </tbody>
  </table></div>
  {% else %}<div class="empty">No categories yet. <a href="/admin/categories/new">Add one</a>.</div>{% endif %}
</div>
{% endblock %}
