{% extends "layout.njk" %}
{% from "public/_macros.njk" import banner %}

{% block content %}
{{ banner('Contact Us', 'Have questions? Reach out to our team for personalized guidance.', [{label:'Contact'}]) }}

<section class="section">
  <div class="container">
    <div class="contact-info-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:var(--space-6);margin-bottom:var(--space-12);">
      <a href="tel:{{ settings.phone }}" class="contact-info-card reveal"><div class="contact-info-card__icon contact-info-card__icon--blue">📞</div><div><strong>Call Us</strong><p>{{ settings.phone }}</p></div></a>
      <a href="mailto:{{ settings.email }}" class="contact-info-card reveal"><div class="contact-info-card__icon contact-info-card__icon--orange">✉️</div><div><strong>Email Us</strong><p>{{ settings.email }}</p></div></a>
      <a href="https://wa.me/{{ settings.whatsapp }}" class="contact-info-card reveal" target="_blank"><div class="contact-info-card__icon contact-info-card__icon--green">💬</div><div><strong>WhatsApp</strong><p>Chat with us</p></div></a>
    </div>

    <div class="contact-grid" style="align-items:start; gap:var(--space-12);">
      <div>
        <h2 class="section-title" style="text-align:left;font-size:var(--fs-2xl);">Our Locations</h2>
        <div class="contact-info-card" style="flex-direction:column;gap:var(--space-4);align-items:flex-start;margin-bottom:var(--space-6);">
          <h3 style="font-size:var(--fs-base);margin:0;color:var(--color-primary);font-weight:var(--fw-semibold);">Headquarters & Main Warehouse</h3>
          <p style="margin:0;">📍 {{ settings.address }}</p>
          <p style="margin:0;">📞 <a href="tel:{{ settings.phone }}" style="color:inherit;">{{ settings.phone }}</a></p>
          <p style="margin:0;">✉️ <a href="mailto:{{ settings.email }}" style="color:inherit;">{{ settings.email }}</a></p>
        </div>
        <div class="contact-info-card" style="flex-direction:column;gap:var(--space-4);align-items:flex-start;">
          <h3 style="font-size:var(--fs-base);margin:0;color:var(--color-primary);font-weight:var(--fw-semibold);">Chennai Warehouse</h3>
          <p style="margin:0;">📍 Stockarea W304, 461/2C, Puzhal Village, Puzhal Ambattur Road, Chennai - 600066</p>
        </div>
      </div>

      <div class="lead-form reveal">
        <h3 class="lead-form__title">Send Us a Message</h3>
        <p class="lead-form__subtitle">Fill out the form and our team will get back to you within 24 hours.</p>
        {% if sent %}<div class="alert" style="background:var(--color-success,#1ea97c);color:#fff;padding:var(--space-4);border-radius:var(--radius);margin-bottom:var(--space-4);">✓ Thank you! We'll contact you soon.</div>{% endif %}
        <form method="post" action="/contact">
          <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);">
            <div class="form-group"><label class="form-label">Full Name *</label><input class="form-input" name="name" required maxlength="160"></div>
            <div class="form-group"><label class="form-label">Company</label><input class="form-input" name="company" maxlength="200"></div>
          </div>
          <div class="form-row" style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);">
            <div class="form-group"><label class="form-label">Mobile *</label><input class="form-input" name="mobile" required maxlength="40"></div>
            <div class="form-group"><label class="form-label">Email *</label><input type="email" class="form-input" name="email" required maxlength="160"></div>
          </div>
          <div class="form-group"><label class="form-label">Subject</label><input class="form-input" name="subject" maxlength="200"></div>
          <div class="form-group"><label class="form-label">Message</label><textarea class="form-textarea" name="message" rows="5" maxlength="2000"></textarea></div>
          <button class="btn btn--primary btn--lg" type="submit">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>
{% endblock %}
