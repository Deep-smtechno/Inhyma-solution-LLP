{% extends "layout.njk" %}
{% from "public/_macros.njk" import productCard %}

{% block content %}
<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero__bg"><img src="/assets/hero-bg.png" alt="Modern automated packaging factory" loading="eager"></div>
  <div class="container">
    <div class="hero__content">
      <div class="hero__badge"><span class="hero__badge-dot"></span> {{ settings.tagline }}</div>
      <h1 class="hero__title">{{ settings.hero_title }}</h1>
      <p class="hero__subtitle">{{ settings.hero_subtitle }}</p>
      <div class="hero__cta">
        <a href="/products" class="btn btn--primary btn--lg">Explore Products</a>
        <a href="/request-quote" class="btn btn--outline-white btn--lg">Request a Quote</a>
      </div>

      {% if stats.length %}
      <div class="hero__stats">
        {% for s in stats %}
        <div class="hero__stat">
          <div class="hero__stat-value">
            <span data-count="{{ s.Value }}" class="counter">0</span><span>{{ s.Suffix }}</span>
          </div>
          <div class="hero__stat-label">{{ s.Label }}</div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- CATEGORIES -->
<section class="section">
  <div class="container">
    <div class="section-header text-center"><span class="section-label">What We Offer</span><h2 class="section-title">Our Product Categories</h2></div>
    <div class="category-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:var(--space-6);margin-top:var(--space-8);">
      {% for c in categories %}
      <a href="/products?category={{ c.Slug }}" class="category-card reveal">
        <div class="category-card__image">
          {% if c.ImagePath %}<img src="{{ c.ImagePath }}" alt="{{ c.Name }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
          {% else %}<div class="category-card__image-placeholder" style="height:100%;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 12h18"/></svg></div>{% endif %}
        </div>
        <div class="category-card__body" style="padding:var(--space-5);">
          <h3 class="category-card__title">{{ c.Name }}</h3>
          <p style="color:var(--color-gray-500);font-size:var(--fs-sm);">{{ c.Description | truncate(80) }}</p>
          <span style="color:var(--color-primary);font-weight:600;">{{ c.ProductCount }} products →</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- FEATURED PRODUCTS -->
{% if featured.length %}
<section class="section section--alt">
  <div class="container">
    <div class="section-header text-center"><span class="section-label">Best Sellers</span><h2 class="section-title">Featured Products</h2></div>
    <div class="product-grid" style="margin-top:var(--space-8);">
      {% for p in featured %}{{ productCard(p) }}{% endfor %}
    </div>
    <div class="text-center" style="margin-top:var(--space-8);"><a href="/products" class="btn btn--primary btn--lg">View All Products</a></div>
  </div>
</section>
{% endif %}

<!-- INDUSTRIES -->
{% if industries.length %}
<section class="section section--alt">
  <div class="container">
    <div class="section-header text-center"><span class="section-label">Industries</span><h2 class="section-title">Industries We Serve</h2></div>
    <div class="industry-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:var(--space-6);margin-top:var(--space-8);">
      {% for i in industries %}
      <a href="/industries/{{ i.Slug }}" class="industry-card reveal">
        <div class="industry-card__bg">
          <img src="{{ i.ImagePath }}" alt="{{ i.Name }}" loading="lazy">
        </div>
        <div class="industry-card__overlay"></div>
        <div class="industry-card__content">
          <div class="industry-card__icon">{{ i.IconEmoji }}</div>
          <h3 class="industry-card__title">{{ i.Name }}</h3>
          <p class="industry-card__desc">{{ i.ShortDescription }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- GLOBAL REACH — Light Premium Redesign -->
<section class="section global-reach-section" id="global-reach" style="background: var(--color-white); border-top: 1px solid var(--color-gray-100); position: relative; overflow: hidden; padding: var(--space-20) 0;">
  <div class="gr-bg-grid" style="position: absolute; inset: 0; pointer-events: none; opacity: 0.3; background-image: radial-gradient(var(--color-gray-200) 1px, transparent 1px); background-size: 24px 24px;"></div>
  
  <div class="container" style="position: relative; z-index: 2;">
    <div class="section-header text-center">
      <span class="section-label">Global Presence</span>
      <h2 class="section-title">Globally Connected, Locally Delivered</h2>
      <p class="section-subtitle" style="max-width: 650px; margin: 0 auto var(--space-8); color: var(--color-gray-500); font-size: var(--fs-base); line-height: var(--lh-relaxed);">
        Empowering industries across borders with dedicated offices, warehouses, and a seamless supply chain network.
      </p>
    </div>

    <!-- Professional Stats Counter Grid -->
    <div class="gr-stats-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4); margin-bottom: var(--space-10); text-align: center;">
      <div class="gr-stat-item" style="padding: var(--space-5); background: var(--color-gray-50); border-radius: var(--radius-md); border: 1px solid var(--color-gray-100); transition: transform 0.3s ease;">
        <div class="gr-stat-value" style="font-size: var(--fs-3xl); font-weight: var(--fw-extrabold); color: var(--color-primary); font-family: var(--font-display);">7</div>
        <div class="gr-stat-label" style="font-size: var(--fs-xs); color: var(--color-gray-500); text-transform: uppercase; letter-spacing: var(--ls-wider); font-weight: var(--fw-semibold); margin-top: var(--space-1);">Countries Served</div>
      </div>
      <div class="gr-stat-item" style="padding: var(--space-5); background: var(--color-gray-50); border-radius: var(--radius-md); border: 1px solid var(--color-gray-100); transition: transform 0.3s ease;">
        <div class="gr-stat-value" style="font-size: var(--fs-3xl); font-weight: var(--fw-extrabold); color: var(--color-primary); font-family: var(--font-display);">3</div>
        <div class="gr-stat-label" style="font-size: var(--fs-xs); color: var(--color-gray-500); text-transform: uppercase; letter-spacing: var(--ls-wider); font-weight: var(--fw-semibold); margin-top: var(--space-1);">Continents</div>
      </div>
      <div class="gr-stat-item" style="padding: var(--space-5); background: var(--color-gray-50); border-radius: var(--radius-md); border: 1px solid var(--color-gray-100); transition: transform 0.3s ease;">
        <div class="gr-stat-value" style="font-size: var(--fs-3xl); font-weight: var(--fw-extrabold); color: var(--color-primary); font-family: var(--font-display);">14+</div>
        <div class="gr-stat-label" style="font-size: var(--fs-xs); color: var(--color-gray-500); text-transform: uppercase; letter-spacing: var(--ls-wider); font-weight: var(--fw-semibold); margin-top: var(--space-1);">Facilities & Hubs</div>
      </div>
      <div class="gr-stat-item" style="padding: var(--space-5); background: var(--color-gray-50); border-radius: var(--radius-md); border: 1px solid var(--color-gray-100); transition: transform 0.3s ease;">
        <div class="gr-stat-value" style="font-size: var(--fs-3xl); font-weight: var(--fw-extrabold); color: var(--color-primary); font-family: var(--font-display);">24/7</div>
        <div class="gr-stat-label" style="font-size: var(--fs-xs); color: var(--color-gray-500); text-transform: uppercase; letter-spacing: var(--ls-wider); font-weight: var(--fw-semibold); margin-top: var(--space-1);">Support & Logistics</div>
      </div>
    </div>
    
    <!-- Map Container -->
    <div class="map-cardreveal reveal" style="position: relative; min-height: 520px; width: 100%;">
      <div id="globalReachMap" style="width: 100%; height: 100%; min-height: 520px; background: transparent; position: relative;"></div>
      
      <!-- Premium Map Legend -->
      <div class="map-legend" style="position: absolute; bottom: var(--space-4); left: var(--space-5); display: flex; gap: var(--space-4); background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(8px); padding: var(--space-2) var(--space-4); border-radius: var(--radius-md); border: 1px solid var(--color-gray-200); z-index: 10;">
        <div style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--fs-xs); color: var(--color-gray-600); font-weight: var(--fw-medium);">
          <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: var(--color-accent); box-shadow: 0 0 6px rgba(232, 114, 42, 0.5);"></span>
          Office & Warehouse
        </div>
        <div style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--fs-xs); color: var(--color-gray-600); font-weight: var(--fw-medium);">
          <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: var(--color-blue); box-shadow: 0 0 6px rgba(43, 94, 167, 0.5);"></span>
          Active Operations
        </div>
        <div style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--fs-xs); color: var(--color-gray-600); font-weight: var(--fw-medium);">
          <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: rgba(203, 213, 225, 0.8);"></span>
          Coverage Area
        </div>
      </div>
    </div>
  </div>
</section>

<!-- BLOG -->
{% if blogs.length %}
<section class="section section--alt">
  <div class="container">
    <div class="section-header text-center"><span class="section-label">Knowledge Center</span><h2 class="section-title">Latest Insights</h2></div>
    <div class="blog-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:var(--space-6);margin-top:var(--space-8);">
      {% for b in blogs %}
      <a href="/blog/{{ b.Slug }}" class="blog-card reveal">
        <div class="blog-card__image">{% if b.ImagePath %}<img src="{{ b.ImagePath }}" alt="{{ b.Title }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;">{% else %}<div class="category-card__image-placeholder" style="height:100%;font-size:2rem;">{{ b.IconEmoji or '📦' }}</div>{% endif %}</div>
        <div class="blog-card__body"><span class="blog-card__tag">{{ b.Tag }}</span><h3 class="blog-card__title">{{ b.Title }}</h3><p class="blog-card__excerpt">{{ b.Excerpt | truncate(110) }}</p><div class="blog-card__meta"><span>{{ b.PublishedDate | date }}</span><span>•</span><span>{{ b.ReadTime }}</span></div></div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- TESTIMONIALS -->
{% if testimonials.length %}
<section class="section" style="overflow: hidden;">
  <div class="container">
    <div class="section-header text-center">
      <span class="section-label">Testimonials</span>
      <h2 class="section-title">What Our Clients Say</h2>
    </div>
  </div>
  <div class="testimonials-marquee reveal">
    <div class="testimonials-marquee__track">
      <div class="testimonials-marquee__group">
        {% for t in testimonials %}
        <div class="testimonial-card">
          <div class="testimonial-card__stars">
            {% for i in range(0, t.Rating) %}★{% endfor %}{% for i in range(t.Rating, 5) %}☆{% endfor %}
          </div>
          <p class="testimonial-card__text">"{{ t.Content }}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">{{ t.Initials or (t.AuthorName | truncate(2, true, '')) }}</div>
            <div>
              <div class="testimonial-card__name">{{ t.AuthorName }}</div>
              <div class="testimonial-card__role">{{ t.AuthorRole }}</div>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="testimonials-marquee__group" aria-hidden="true">
        {% for t in testimonials %}
        <div class="testimonial-card">
          <div class="testimonial-card__stars">
            {% for i in range(0, t.Rating) %}★{% endfor %}{% for i in range(t.Rating, 5) %}☆{% endfor %}
          </div>
          <p class="testimonial-card__text">"{{ t.Content }}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">{{ t.Initials or (t.AuthorName | truncate(2, true, '')) }}</div>
            <div>
              <div class="testimonial-card__name">{{ t.AuthorName }}</div>
              <div class="testimonial-card__role">{{ t.AuthorRole }}</div>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% endif %}

<!-- CTA -->
<section class="section section--primary"><div class="container text-center">
  <h2 class="section-title" style="color:var(--color-white);">Ready to Automate Your Business?</h2>
  <p style="color:rgba(255,255,255,0.7);max-width:560px;margin:0 auto var(--space-8);">Let our experts design a tailored solution that maximizes your ROI.</p>
  <div class="btn-group" style="justify-content:center;"><a href="/request-quote" class="btn btn--primary btn--lg">Request a Quote</a><a href="/contact" class="btn btn--outline-white btn--lg">Contact Us</a></div>
</div></section>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener("DOMContentLoaded", function() {
  const container = document.getElementById("globalReachMap");
  container.innerHTML = '<canvas id="globalReachMapCanvas" style="width:100%; height:100%; display:block; cursor:pointer;"></canvas><div id="mapTooltip" class="gr-tooltip"></div>';
  
  const canvas = document.getElementById("globalReachMapCanvas");
  const tooltip = document.getElementById("mapTooltip");
  const ctx = canvas.getContext("2d");
  
  let dots = [];
  let hoverCountryCode = null;
  let activeCountryCode = null;
  let animTime = 0;
  
  function latLngToVirtual(lng, lat) {
    const xVal = lng + 180;
    const clampedLat = Math.max(-80, Math.min(80, lat));
    const latRad = clampedLat * Math.PI / 180;
    const mercY = Math.log(Math.tan((Math.PI / 4) + (latRad / 2)));
    const maxMercY = 2.436;
    const yVal = (maxMercY - mercY) * (360 / (2 * Math.PI));
    return { x: xVal, y: yVal };
  }

  const cities = [
    { name: 'India', desc: 'Global Headquarters & Warehouse', ...latLngToVirtual(78.9629, 20.5937), code: 'IN' },
    { name: 'China', desc: 'Regional Office & Distribution Hub', ...latLngToVirtual(104.1954, 35.8617), code: 'CN' },
    { name: 'Hong Kong', desc: 'Global Logistics Hub', ...latLngToVirtual(114.1694, 22.3193), code: 'HK' },
    { name: 'UAE', desc: 'Middle East Distribution Hub', ...latLngToVirtual(53.8478, 23.4241), code: 'AE' },
    { name: 'Kenya', desc: 'East Africa Regional Office', ...latLngToVirtual(37.9062, -0.0236), code: 'KE' },
    { name: 'Uganda', desc: 'East Africa Distribution Warehouse', ...latLngToVirtual(32.2903, 1.3733), code: 'UG' },
    { name: 'Rwanda', desc: 'East Africa Operations Center', ...latLngToVirtual(29.8739, -1.9403), code: 'RW' }
  ];



  function resizeCanvas() {
    const rect = container.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    canvas.style.width = `${rect.width}px`;
    canvas.style.height = `${rect.height}px`;
  }
  
  fetch('/data/world_dots_slim.json')
    .then(r => r.json())
    .then(data => {
      dots = data;
      window.addEventListener('resize', () => { resizeCanvas(); });
      resizeCanvas();
      function animate() {
        animTime += 0.012;
        draw();
        requestAnimationFrame(animate);
      }
      animate();
    });

  function getCanvasCoords(xVal, yVal, w, h) {
    const mapWidth = 360, mapHeight = 205.69;
    const mapAR = mapWidth / mapHeight;
    let scale, offsetX, offsetY;
    if (w / h > mapAR) {
      scale = h / mapHeight; offsetX = (w - mapWidth * scale) / 2; offsetY = 0;
    } else {
      scale = w / mapWidth; offsetX = 0; offsetY = (h - mapHeight * scale) / 2;
    }
    return { x: offsetX + xVal * scale, y: offsetY + yVal * scale };
  }

  function draw() {
    const rect = canvas.getBoundingClientRect();
    const w = rect.width, h = rect.height;
    
    // Clear canvas
    ctx.clearRect(0, 0, w, h);
    
    // Draw dot matrix world map
    dots.forEach(d => {
      const coords = getCanvasCoords(d.x, d.y, w, h);
      const isActive = (d.c && (d.c === hoverCountryCode || d.c === activeCountryCode));
      const isTarget = d.t === 1;
      if (isActive) {
        ctx.fillStyle = '#1B3A5C'; // Primary navy (high contrast)
        ctx.shadowColor = 'rgba(27, 58, 92, 0.3)';
        ctx.shadowBlur = 4;
      } else if (isTarget) {
        ctx.fillStyle = 'rgba(43, 94, 167, 0.8)'; // Denser brand blue (high contrast)
        ctx.shadowColor = 'transparent';
        ctx.shadowBlur = 0;
      } else {
        ctx.fillStyle = 'rgba(100, 116, 139, 0.4)'; // Clear slate gray (high contrast against white)
        ctx.shadowColor = 'transparent';
        ctx.shadowBlur = 0;
      }
      
      ctx.beginPath();
      const radius = isActive ? 1.8 : (isTarget ? 1.15 : 0.7);
      ctx.arc(coords.x, coords.y, radius, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;
    });
    
    // Draw city markers with high-end double pulsing rings
    cities.forEach((c, i) => {
      const coords = getCanvasCoords(c.x, c.y, w, h);
      const isHovered = (c.code === hoverCountryCode || c.code === activeCountryCode);
      const phase = animTime * 2 + i * 0.8;
      
      // Pulsing outer ring (Orange Accent)
      const pulseRadius = 8 + (phase % 1) * 12;
      const pulseOpacity = 1 - (phase % 1);
      ctx.beginPath();
      ctx.arc(coords.x, coords.y, pulseRadius, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(232, 114, 42, ${pulseOpacity * 0.25})`;
      ctx.fill();
      
      // Solid outer ring
      ctx.beginPath();
      ctx.arc(coords.x, coords.y, isHovered ? 6 : 4.5, 0, Math.PI * 2);
      ctx.fillStyle = isHovered ? 'rgba(232, 114, 42, 0.3)' : 'rgba(43, 94, 167, 0.2)';
      ctx.fill();
      
      // Core center dot
      ctx.beginPath();
      ctx.arc(coords.x, coords.y, isHovered ? 4.5 : 3.5, 0, Math.PI * 2);
      ctx.fillStyle = isHovered ? '#E8722A' : '#2B5EA7'; // Orange on hover, Blue otherwise
      ctx.strokeStyle = '#ffffff';
      ctx.lineWidth = 1.2;
      ctx.fill();
      ctx.stroke();
    });
  }
  
  // Interactive events
  canvas.addEventListener('mousemove', function(e) {
    const rect = canvas.getBoundingClientRect();
    const mouseX = e.clientX - rect.left;
    const mouseY = e.clientY - rect.top;
    
    let hoveredCity = null;
    cities.forEach(c => {
      const coords = getCanvasCoords(c.x, c.y, rect.width, rect.height);
      const dx = mouseX - coords.x, dy = mouseY - coords.y;
      if (Math.sqrt(dx*dx + dy*dy) < 16) hoveredCity = c;
    });

    let closestDot = null, minDist = 8;
    if (!hoveredCity) {
      dots.forEach(d => {
        if (!d.t) return;
        const coords = getCanvasCoords(d.x, d.y, rect.width, rect.height);
        const dx = mouseX - coords.x, dy = mouseY - coords.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < minDist) { minDist = dist; closestDot = d; }
      });
    }
    
    const prev = hoverCountryCode;
    
    if (hoveredCity) {
      hoverCountryCode = hoveredCity.code;
      tooltip.style.display = 'block';
      tooltip.style.left = `${e.clientX - rect.left + 15}px`;
      tooltip.style.top = `${e.clientY - rect.top - 15}px`;
      tooltip.innerHTML = `<div style="font-weight: 700; color: var(--color-primary);">${hoveredCity.name}</div><div style="font-size: 11px; color: var(--color-gray-50); margin-top: 2px;">${hoveredCity.desc}</div>`;
    } else if (closestDot) {
      hoverCountryCode = closestDot.c;
      tooltip.style.display = 'block';
      tooltip.style.left = `${e.clientX - rect.left + 15}px`;
      tooltip.style.top = `${e.clientY - rect.top - 15}px`;
      tooltip.innerHTML = `<div style="font-weight: 700; color: var(--color-primary);">${closestDot.c}</div><div style="font-size: 11px; color: var(--color-gray-50); margin-top: 2px;">Active Regional Operations</div>`;
    } else {
      hoverCountryCode = null;
      tooltip.style.display = 'none';
    }
  });
  
  canvas.addEventListener('mouseleave', function() {
    hoverCountryCode = null;
    tooltip.style.display = 'none';
  });
});
</script>
<style>
/* --- Premium Light Tooltip --- */
.gr-tooltip {
  position: absolute;
  display: none;
  pointer-events: none;
  background: var(--color-primary);
  color: var(--color-white);
  border: 1px solid var(--color-primary-light);
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-md);
  font-size: var(--fs-xs);
  z-index: 1000;
  box-shadow: var(--shadow-lg);
  font-family: var(--font-primary);
  line-height: var(--lh-tight);
}

/* --- Stats Hover --- */
.gr-stat-item:hover {
  transform: translateY(-2px);
  border-color: var(--color-gray-300) !important;
  background: var(--color-white) !important;
  box-shadow: var(--shadow-sm);
}

/* Responsive tweaks */
@media (max-width: 991px) {
  .gr-stats-grid {
    grid-template-columns: 1fr 1fr !important;
    gap: var(--space-3) !important;
  }
}
@media (max-width: 768px) {
  .map-cardreveal {
    min-height: 380px !important;
  }
  #globalReachMap {
    min-height: 380px !important;
  }
  .map-legend {
    flex-direction: column;
    gap: var(--space-1) !important;
    left: var(--space-3) !important;
    bottom: var(--space-3) !important;
  }
}
@media (max-width: 480px) {
  .gr-stats-grid {
    grid-template-columns: 1fr !important;
  }
}
</style>
{% endblock %}

