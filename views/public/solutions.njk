{% extends "layout.njk" %}
{% from "public/_macros.njk" import banner %}

{% block content %}
{{ banner('Industrial Solutions', 'We engineer complete business solutions that transform your operations and drive measurable results.', [{label:'Solutions'}]) }}

<section class="section section--alt">
  <div class="container">
    <div class="solution-page-grid-new">
      {% for s in solutions %}
      <div class="solution-page-card-new reveal">
        <!-- Background Image -->
        <div class="solution-page-card-new__bg">
          {% if s.ImagePath %}
            <img src="{{ s.ImagePath }}" alt="{{ s.Title }}" loading="lazy">
          {% else %}
            <div class="category-card__image-placeholder" style="height:100%; min-height:300px;">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 12h18M12 3v18"/>
              </svg>
            </div>
          {% endif %}
        </div>
        
        <!-- Overlay -->
        <div class="solution-page-card-new__overlay"></div>
        
        <!-- Content -->
        <div class="solution-page-card-new__content">
          <span class="solution-page-card-new__index">Solution 0{{ loop.index }}</span>
          <h3 class="solution-page-card-new__title">{{ s.Title }}</h3>
          <p class="solution-page-card-new__desc">{{ s.Description | safe }}</p>
          
          <!-- Features Checklist -->
          {% if s.features and s.features.length > 0 %}
          <ul class="solution-page-card-new__features">
            {% for f in s.features %}
            <li class="solution-page-card-new__feature-item">
              <span class="solution-page-card-new__feature-icon">✓</span>
              <span>{{ f.FeatureText }}</span>
            </li>
            {% endfor %}
          </ul>
          {% endif %}
          
          <!-- Actions -->
          <div class="solution-page-card-new__cta">
            <a href="/request-quote?product={{ s.Title | urlencode }}" class="btn btn--primary btn--sm">Request Consultation</a>
            <a href="https://wa.me/{{ settings.whatsapp }}?text=Hello,%20I'm%20interested%20in%20your%20{{ s.Title | urlencode }}%20solution." class="btn btn--outline-white btn--sm" target="_blank">Chat</a>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>


<section class="section section--primary">
  <div class="container text-center">
    <h2 class="section-title" style="color:var(--color-white);">Let's Design Your Custom Solution</h2>
    <p style="color:rgba(255,255,255,0.7);max-width:560px;margin:0 auto var(--space-8);">Every business is unique. Let our experts design a tailored automation solution.</p>
    <div class="btn-group" style="justify-content:center;">
      <a href="/request-quote" class="btn btn--primary btn--lg">Request Consultation</a>
      <a href="https://wa.me/{{ settings.whatsapp }}" class="btn btn--outline-white btn--lg" target="_blank">Chat on WhatsApp</a>
    </div>
  </div>
</section>
{% endblock %}
