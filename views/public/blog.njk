{% extends "layout.njk" %}
{% from "public/_macros.njk" import banner %}

{% block content %}
{{ banner('Knowledge Center', 'Expert insights, buying guides, industry trends, and case studies.', [{label:'Knowledge Center'}]) }}

<section class="section">
  <div class="container">
    {% if posts.length %}
    <div class="blog-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:var(--space-6);">
      {% for b in posts %}
      <a href="/blog/{{ b.Slug }}" class="blog-card reveal">
        <div class="blog-card__image">{% if b.ImagePath %}<img src="{{ b.ImagePath }}" alt="{{ b.Title }}" style="width:100%;height:100%;object-fit:cover;">{% else %}<div class="category-card__image-placeholder" style="height:100%;font-size:2rem;">{{ b.IconEmoji or '📦' }}</div>{% endif %}</div>
        <div class="blog-card__body">
          <span class="blog-card__tag">{{ b.Tag }}</span>
          <h3 class="blog-card__title">{{ b.Title }}</h3>
          <p class="blog-card__excerpt">{{ b.Excerpt | truncate(120) }}</p>
          <div class="blog-card__meta"><span>{{ b.PublishedDate | date }}</span><span>•</span><span>{{ b.ReadTime }}</span></div>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p class="text-center" style="color:var(--color-gray-500);">No articles published yet.</p>
    {% endif %}
  </div>
</section>
{% endblock %}
